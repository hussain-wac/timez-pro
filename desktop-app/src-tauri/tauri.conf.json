{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Timez Pro",
  "version": "0.1.1",
  "identifier": "com.wac.timez-clone",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && npm run tauri:prepare-service -- --release",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Timez Pro",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/timez-auth-service": "timez-auth-service",
      "resources/timez-task-service": "timez-task-service",
      "resources/timez-tracker-service": "timez-tracker-service",
      "resources/timez-idle-time-service": "timez-idle-time-service",
      "resources/timez-quit-service": "timez-quit-service"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
